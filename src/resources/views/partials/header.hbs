<header> 
    <div class="header-container">
        <div class="logo">
            <a href="/">BOOK STORE</a>
        </div>

        <form action="/" method="GET" class="search-form">
            <div class="search-box-wrapper">
                <select name="category" class="category-select" onchange="this.form.submit()">
                    <option value="">Tất cả loại sách</option>
                    {{#each allCategories}}
                        <option value="{{this.id}}" {{#if (eq ../currentCategory this.id)}}selected{{/if}}>
                            {{this.name}}
                        </option>
                    {{/each}}
                </select>

                <input type="text" name="search" placeholder="Tìm tên sách, tác giả..." class="search-input" value="{{keyword}}">
                
                <button type="submit" class="search-btn">
                    <i class="fas fa-search">Tìm</i>
                </button>
            </div>
        </form>

        <div class="auth-buttons">
            {{#if user}}
                <div style="display: flex; align-items: center; gap: 10px;">
                    {{!-- AVATAR TRÊN HEADER --}}
                    <a href="/profile">
                        <img src="https://ui-avatars.com/api/?name={{user.username}}&background=0056b3&color=fff&rounded=true" 
                            alt="{{user.username}}" 
                            style="width: 35px; height: 35px; border: 2px solid #007bff; border-radius: 50%;">
                    </a>

                    <span class="user-name">Chào, 
                        <a href="/profile" style="text-decoration: none; font-weight: bold; color: #007bff; border-bottom: 1px dashed #007bff;">
                            {{user.username}}
                        </a>
                    </span>
                    <a href="/logout" class="btn-logout-nav">Đăng xuất</a>
                </div>
            {{else}}
                <a href="/login" class="btn-login-nav">Đăng nhập</a>
                <a href="/signup" class="btn-signup-nav">Đăng ký</a>
            {{/if}}
        </div>
    </div>
</header>