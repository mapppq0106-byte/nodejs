<div class="container" style="margin-top: 30px;">
    <div style="display: flex; gap: 40px; align-items: flex-start;">
        <img src="/img/{{book.image_url}}" alt="{{book.title}}" style="width: 300px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.1);"> 
        <div style="flex: 1;">
            <h1 style="margin-bottom: 3px;">{{book.title}}</h1> 

            <p style="color: #000000; font-size: 1.1rem;">Tác giả: <strong>{{book.author}}</strong></p> 
            <br>
            <p><strong>Danh mục:</strong> <span class="badge-category" style="background: #e9ecef; padding: 4px 12px; border-radius: 20px; font-size: 0.9rem;">{{book.category_name}}</span></p>

            <div class="book-actions" style="margin-top: 20px;">
                {{#if user}}
                    <a href="/book/read/{{book.id}}" class="btn-auth" style="text-decoration:none; background: #28a745;">ĐỌC SÁCH NGAY</a>
                {{else}}
                    <a href="/login" class="btn-auth" style="text-decoration:none; background: #28a745;" 
                        onclick="return confirm('Bạn cần đăng nhập để sử dụng chức năng này. Chuyển đến trang đăng nhập?')">
                        Đọc sách ngay
                    </a>
                {{/if}}
            </div>

            <p style="font-size: 1.8rem; color: #4da3ff; margin: 15px 0; font-weight: 700;">{{book.price}} VNĐ</p> 
            <div style="background: rgba(0, 0, 0, 0.03); padding: 20px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.05);"> 
                <h4 style="margin-bottom: 10px; color: #000000;">Mô tả nội dung:</h4> 
                <p style="color: #000000; line-height: 1.6;">{{book.description}}</p> 
            </div>
        </div>
    </div>

    <hr style="margin: 40px 0; border: 0.5px solid #ddd;"> 

    <section class="reviews-section">
        <h3 style="margin-bottom: 25px; font-size: 1.5rem;">Đánh giá từ cộng đồng</h3> 
        
        {{#if user}}
            {{#if hasReviewed}}
                <div style="background: #e7f3ff; border: 1px solid #4da3ff; padding: 15px; border-radius: 10px; color: #0056b3; margin-bottom: 30px;"> 
                    <i class="fas fa-check-circle"></i> Bạn đã gửi đánh giá cho cuốn sách này. 
                </div>
            {{else}}
                <form action="/book/{{book.id}}/review" method="POST" style="background: rgba(0, 0, 0, 0.02); padding: 25px; border-radius: 15px; border: 1px solid #eee; margin-bottom: 40px;"> 
                    <div class="form-group" style="margin-bottom: 15px;"> 
                        <label style="display: block; margin-bottom: 8px; font-weight: 600;">Mức độ hài lòng:</label> 
                        <select name="rating" class="form-input" style="width: auto; min-width: 150px; padding: 8px; border-radius: 5px; border: 1px solid #ddd;"> 
                            <option value="5">5 Sao ⭐⭐⭐⭐⭐</option> 
                            <option value="4">4 Sao ⭐⭐⭐⭐</option> 
                            <option value="3">3 Sao ⭐⭐⭐</option> 
                            <option value="2">2 Sao ⭐⭐</option> 
                            <option value="1">1 Sao ⭐</option> 
                        </select>
                    </div> 

                    <div class="form-group" style="margin-bottom: 15px;"> 
                        <label style="display: block; margin-bottom: 8px; font-weight: 600;">Nhận xét chi tiết:</label> 
                        <textarea name="comment" class="form-input" rows="4" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #ddd;" placeholder="Chia sẻ cảm nghĩ của bạn về cuốn sách..." required></textarea> 
                    </div>

                    <div class="form-group" style="margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                        <input type="checkbox" name="is_anonymous" id="is_anonymous" style="width: 18px; height: 18px; cursor: pointer;">
                        <label for="is_anonymous" style="cursor: pointer; color: #555; font-size: 0.95rem;">Gửi đánh giá ẩn danh (Tên bạn sẽ không được hiển thị)</label>
                    </div>

                    <button type="submit" class="btn-auth" style="width: auto; padding: 12px 40px; background: #007bff; color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600;">
                        <i class="fas fa-paper-plane"></i> Gửi Đánh Giá
                    </button> 
                </form>
            {{/if}}
        {{else}}
            <p style="margin-bottom: 30px; color: #666; background: #f8f9fa; padding: 15px; border-radius: 8px; border-left: 4px solid #4da3ff;">
                Bạn cần <a href="/login" style="color: #4da3ff; text-decoration: underline; font-weight: 600;">đăng nhập</a> để gửi đánh giá cho cuốn sách này.
            </p> 
        {{/if}}

        <div class="reviews-list">
            {{#each reviews}}
                <div style="padding: 20px; background: #fff; border-radius: 12px; margin-bottom: 15px; border: 1px solid #eee; box-shadow: 0 2px 5px rgba(0,0,0,0.02);"> 
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;"> 
                        <span style="font-size: 1.1rem;">
                            {{#if (eq this.username 'Người dùng ẩn danh')}}
                                <strong style="color: #888; font-style: italic;"><i class="fas fa-user-secret"></i> {{this.username}}</strong>
                            {{else}}
                                <strong style="color: #333;">{{this.username}}</strong>
                            {{/if}}
                        </span>
                        <span style="color: #ffcc00; font-weight: bold;">{{this.rating}} ⭐</span> 
                    </div>
                    <p style="color: #666; font-size: 0.85rem; margin-bottom: 10px;"><i class="far fa-clock"></i> {{formatDate this.created_at}}</p>
                    <p style="color: #444; line-height: 1.5; white-space: pre-line;">{{this.comment}}</p> 
                </div>
            {{else}}
                <div style="color: #999; text-align: center; padding: 40px; background: #fcfcfc; border-radius: 12px; border: 1px dashed #ddd;">
                    <i class="fas fa-comment-slash" style="font-size: 2rem; display: block; margin-bottom: 10px;"></i>
                    Cuốn sách này chưa có đánh giá nào. Hãy là người đầu tiên nhận xét!
                </div>
            {{/each}}
        </div>
    </section>
</div>