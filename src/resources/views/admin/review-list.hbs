<div class="container" style="margin-top: 30px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 style="color: #333;"><i class="fas fa-comments"></i> Danh Sách Đánh Giá</h2>
        <div style="display: flex; gap: 10px;">
            <a href="/admin/dashboard" class="btn-auth" style="text-decoration: none; background: #007bff; color: white; padding: 8px 15px; border-radius: 4px; font-size: 14px;">
                <i class="fas fa-book"></i> Quản lý Sách
            </a>
            <a href="/admin/users" class="btn-auth" style="text-decoration: none; background: #6c757d; color: white; padding: 8px 15px; border-radius: 4px; font-size: 14px;">
                <i class="fas fa-users"></i> Người dùng
            </a>
        </div>
    </div>

    <table class="admin-table">
        <thead>
            <tr style="background: #212529; color: white;">
                <th style="padding: 15px;">Người dùng</th>
                <th style="padding: 15px;">Tên sách</th>
                <th style="padding: 15px; text-align: center;">Điểm</th>
                <th style="padding: 15px;">Nội dung</th>
                <th style="padding: 15px; text-align: right;">Ngày gửi</th>
            </tr>
        </thead>
        <tbody>
            {{#each reviews}}
            <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 15px;">
                    <span style="font-weight: 500; color: #333;">{{this.username}}</span>
                </td>
                <td style="padding: 15px;"><strong>{{this.book_title}}</strong></td>
                <td style="padding: 15px; text-align: center;">
                    <span style="color: #ffcc00; font-weight: bold;">{{this.rating}} ⭐</span>
                </td>
                <td style="padding: 15px; max-width: 400px; word-wrap: break-word; color: #555; line-height: 1.4;">
                    {{this.comment}}
                </td>
                <td style="padding: 15px; text-align: right; color: #888; font-size: 0.85rem; white-space: nowrap;">
                    {{formatDate this.created_at}}
                </td>
            </tr>
            {{else}}
            <tr>
                <td colspan="5" style="text-align: center; padding: 30px; color: #999; font-style: italic;">
                    Chưa có đánh giá nào để hiển thị.
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>

<style>
    .admin-table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
    .admin-table th { text-align: left; font-weight: 500; }
    .admin-table td { vertical-align: middle; }
    .admin-table tr:hover { background-color: #fcfcfc; }
</style>