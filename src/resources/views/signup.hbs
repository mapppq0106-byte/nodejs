<div class="auth-wrapper">
    <div class="auth-container">
        <h2>Đăng Ký Thành Viên</h2>
        
        {{!-- PHẦN HIỂN THỊ THÔNG BÁO LỖI (Đồng bộ với Login) --}}
        {{#if error}}
            <div class="auth-error-msg" style="background-color: #f8d7da; color: #721c24; padding: 12px; border-radius: 8px; border: 1px solid #f5c6cb; margin-bottom: 20px; font-size: 0.9rem; display: flex; align-items: center; gap: 10px;">
                <i class="fas fa-exclamation-circle"></i>
                <span>{{error}}</span>
            </div>
        {{/if}}

        <form action="/signup" method="POST">
            <div class="form-group">
                <label>Tên đăng nhập</label>
                {{!-- Sử dụng data.username để giữ lại giá trị khi render lại trang --}}
                <input type="text" name="username" value="{{data.username}}" class="form-input" placeholder="Ví dụ: quyphan123" required>
            </div>
            
            <div class="form-group">
                <label>Email</label>
                {{!-- Sử dụng data.email để giữ lại giá trị --}}
                <input type="email" name="email" value="{{data.email}}" class="form-input" placeholder="example@gmail.com" required>
            </div>

            <div class="form-group">
                <label>Mật khẩu</label>
                <input type="password" name="password" class="form-input" 
                       placeholder="Tối thiểu 8 ký tự, có chữ hoa và số" required>
                <small style="display: block; margin-top: 8px; color: #636e72; font-size: 0.8rem; line-height: 1.4;">
                    * Ít nhất 8 ký tự, bao gồm 1 chữ hoa, 1 chữ thường và 1 chữ số.
                </small>
            </div>

            <button type="submit" class="btn-auth">ĐĂNG KÝ NGAY</button>
        </form>

        <div class="auth-footer">
            Đã có tài khoản? <a href="/login">Đăng nhập tại đây</a>
        </div>
    </div>
</div>

<style>
    /* Hiệu ứng rung nhẹ khi có lỗi để gây chú ý giống trang Login */
    .auth-error-msg {
        animation: shake 0.5s ease-in-out;
    }

    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-5px); }
        75% { transform: translateX(5px); }
    }

    .auth-container {
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        border-radius: 15px;
        background: white;
        padding: 30px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #2d3436;
    }
</style>